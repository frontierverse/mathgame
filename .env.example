# PostgreSQL is used in development and production after the DB transition.

# Use the pooled runtime URL for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true&sslmode=require&uselibpqcompat=true"

# Optional: use a direct, non-pooling URL for Prisma migrations when your
# provider gives separate pooled and direct URLs.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&uselibpqcompat=true"

# Use a long random secret in production. Do not reuse this placeholder.
AUTH_SECRET="replace-with-a-long-random-secret"

# Local development can use local disk.
# Production recommendation: Supabase Storage private bucket.
ATTACHMENT_STORAGE_DRIVER="local"

# ATTACHMENT_STORAGE_DRIVER="supabase-storage"
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_STORAGE_BUCKET="approval-attachments"

# Vercel Blob is still supported if you prefer it.
# ATTACHMENT_STORAGE_DRIVER="vercel-blob"
# BLOB_READ_WRITE_TOKEN=""

# One-time production admin creation script.
# INITIAL_ADMIN_EMAIL=""
# INITIAL_ADMIN_PASSWORD=""
# INITIAL_ADMIN_NAME="운영 관리자"
